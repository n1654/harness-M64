# ===== GigaChat =====

# Auth mode: 'credentials' (Basic auth with GIGACHAT_AUTH_KEY)
#         or 'mtls'        (mutual TLS — client certificate is the credential)
GIGACHAT_AUTH_MODE=credentials

# --- credentials-mode settings ---
# Base64 of "client_id:client_secret" from developers.sber.ru
GIGACHAT_AUTH_KEY=
# Scope: GIGACHAT_API_PERS (individual) or GIGACHAT_API_CORP (corporate)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# --- mTLS-mode settings (uncomment & set when GIGACHAT_AUTH_MODE=mtls) ---
# GIGACHAT_CLIENT_CERT=/app/certs/client.pem
# GIGACHAT_CLIENT_KEY=/app/certs/client.key
# GIGACHAT_CLIENT_KEY_PASSWORD=

# --- TLS verification (applies to both auth modes) ---
# Custom CA bundle path — typical when the Russian Trust CA chain is missing
# from the base image. The bundle should contain the full chain.
# GIGACHAT_CA_BUNDLE=/app/certs/russian-trust-ca.pem
# Set to 1 to disable TLS verification ENTIRELY (insecure, dev/testing only).
GIGACHAT_TLS_INSECURE=0

# --- Model + endpoints (override only if needed) ---
GIGACHAT_MODEL=GigaChat
# GIGACHAT_TOKEN_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
# GIGACHAT_TIMEOUT=120

# --- Custom HTTP headers (JSON object) ---
# Applied to BOTH token and chat requests. User-defined headers go first;
# protocol headers (Authorization, RqUID, Content-Type) always win over them.
# Useful for routing tags, User-Agent overrides, proxy hints.
# GIGACHAT_HEADERS={"X-Custom-Header": "value", "User-Agent": "custom-client"}

# --- Tool / function-calling wire format ---
# 'functions' (default) -- legacy GigaChat schema documented at developers.sber.ru
#                          (`functions: [...]`, `function_call: "auto"`, tool result
#                          messages use `role: "function"`).
# 'tools'               -- OpenAI-compatible schema (`tools: [...]`,
#                          `tool_choice: "auto"`, tool result messages use
#                          `role: "tool"`). Use this if you talk to GigaChat
#                          through an OpenAI-compatible proxy / gateway.
GIGACHAT_TOOL_FORMAT=functions

# --- Content moderation ---
# Server-side profanity filter. Sent on every chat request.
# true (default) — GigaChat masks profanity in its replies.
# false          — pass through as-is (use with care).
GIGACHAT_PROFANITY_CHECK=true

# ===== Harness runtime (all optional) =====
# HARNESS_UI_PORT=8080
# HARNESS_MONITOR_PORT=9090
# HARNESS_CONTROL_PORT=7000
# HARNESS_LOG_LEVEL=info
